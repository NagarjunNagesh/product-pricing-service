<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">
    <springProperty scope="context" name="APP_NAME" source="spring.application.name"
        defaultValue="product-pricing-service" />
    <property name="LOG_PATH" value="${LOG_PATH:-logs}" />
    <property name="LOG_FILE" value="${LOG_FILE:-${LOG_PATH}/${APP_NAME}.log}" />
    <property name="CONSOLE_PATTERN"
        value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%thread] %logger{36} trace=%X{traceId:-} span=%X{spanId:-} - %msg%n" />
    <property name="FILE_PATTERN"
        value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5level [%thread] %logger{36} trace=%X{traceId:-} span=%X{spanId:-} - %msg%n" />

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="ROLLING_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>${LOG_MAX_FILE_SIZE:-25MB}</maxFileSize>
            <maxHistory>${LOG_MAX_HISTORY_DAYS:-30}</maxHistory>
            <totalSizeCap>${LOG_TOTAL_SIZE_CAP:-3GB}</totalSizeCap>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
    </appender>

    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>${LOG_ASYNC_QUEUE_SIZE:-8192}</queueSize>
        <discardingThreshold>${LOG_ASYNC_DISCARD_THRESHOLD:-0}</discardingThreshold>
        <neverBlock>true</neverBlock>
        <appender-ref ref="ROLLING_FILE" />
    </appender>

    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="ASYNC_FILE" />
        </root>

        <logger name="org.springframework" level="INFO" />
        <logger name="org.hibernate" level="WARN" />
        <logger name="org.hibernate.SQL" level="WARN" />
        <logger name="org.springframework.web" level="INFO" />
        <logger name="com.example" level="INFO" />
    </springProfile>

    <springProfile name="!prod">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE" />
        </root>

        <logger name="org.springframework" level="INFO" />
        <logger name="org.hibernate" level="INFO"/>
        <logger name="com.zaxxer.hikari" level="INFO"/>
        <logger name="com.example" level="DEBUG" />
    </springProfile>
</configuration>